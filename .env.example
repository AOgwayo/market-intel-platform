# Example environment variables for Market Intel Platform

# General environment (dev | prod | staging)
ENVIRONMENT=dev

# Polygon API key (optional currently; required for real Polygon ingestion)
POLYGON_API_KEY=your_polygon_api_key_here

# Override default Binance base URL if necessary
BINANCE_BASE_URL=https://api.binance.com

# Ingestion interval for bar collection (seconds)
INGESTION_BAR_INTERVAL_SECONDS=60
