# Example environment configuration for Market Intelligence Platform
# Copy this file to .env and update with your actual values

# Application Environment (development, staging, production)
APP_ENV=development

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Database Connection String (REQUIRED)
# Example for PostgreSQL: postgresql://username:password@hostname:port/database
DB_DSN=postgresql://username:password@localhost:5432/market_intel

# Ingestion Configuration
INGEST_POLL_INTERVAL_SECONDS=60
INGEST_BATCH_SIZE=500

# Retry Configuration  
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY=0.5
RETRY_MAX_DELAY=30.0

# Optional: Default timeframe for bar data
# Examples: 1m, 5m, 15m, 1h, 1d
# BARS_TIMEFRAME_DEFAULT=1m